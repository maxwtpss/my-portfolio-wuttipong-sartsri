62\340\271\204\340\270\233\340\271\203\340\270\231\340\270\252\340\271\210\340\270\247\340\270\231\340\270\227\340\270\261\340\270\201\340\270\251\340\270\260\340\271\201\340\270\245\340\270\260\340\270\232\340\270\243\340\270\243\340\270\227\340\270\261\340\270\224\340\270\220\340\270\262\340\270\231\340\270\204\340\270\247\340\270\262\340\270\241\340\270\243\340\270\261\340\270\232\340\270\234\340\270\264\340\270\224\340\270\212\340\270\255\340\270\232\n*   **\340\270\224\340\270\265\340\271\204\340\270\213\340\270\231\340\271\214\340\270\227\340\270\265\340\271\210\340\270\224\340\270\271\340\271\200\340\270\233\340\271\207\340\270\231\340\270\241\340\270\267\340\270\255\340\270\255\340\270\262\340\270\212\340\270\265\340\270\236\340\271\201\340\270\245\340\270\260\340\270\252\340\270\260\340\270\255\340\270\262\340\270\224\340\270\225\340\270\262 (Clean Slate Theme):** \340\271\203\340\270\212\340\271\211\340\271\202\340\270\227\340\270\231\340\270\252\340\270\265\340\270\231\340\271\211\340\270\263\340\271\200\340\270\207\340\270\264\340\270\231\340\270\204\340\270\243\340\270\262\340\270\241 (Indigo) \340\271\201\340\270\245\340\270\260\340\270\252\340\270\265\340\271\200\340\270\227\340\270\262\340\270\253\340\270\264\340\270\231 (Slate) \340\271\200\340\270\236\340\270\267\340\271\210\340\270\255\340\271\203\340\270\253\340\271\211\340\271\200\340\270\247\340\271\207\340\270\232\340\271\204\340\270\213\340\270\225\340\271\214\340\270\224\340\270\271\340\270\231\340\271\210\340\270\262\340\271\200\340\270\212\340\270\267\340\271\210\340\270\255\340\270\226\340\270\267\340\270\255 \340\270\227\340\270\261\340\270\231\340\270\252\340\270\241\340\270\261\340\270\242 \340\271\201\340\270\245\340\270\260\340\270\255\340\271\210\340\270\262\340\270\231\340\270\207\340\271\210\340\270\262\340\270\242 \340\270\210\340\270\261\340\270\224\340\271\201\340\270\232\340\271\210\340\270\207\340\270\255\340\270\255\340\270\201\340\271\200\340\270\233\340\271\207\340\270\231