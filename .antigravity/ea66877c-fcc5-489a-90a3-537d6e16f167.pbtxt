    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "export default function App() {\n  const [isScrolled, setIsScrolled] = useState(false);\n\n  useEffect(() => {\n      const handleScroll = () => {\n          setIsScrolled(window.scrollY > 50);\n      };\n      window.addEventListener(\'scroll\', handleScroll);\n      return () => window.removeEventListener(\'scroll\', handleScroll);\n  }, []);\n\n  return (\n      <div className=\"min-h-screen bg-zinc-50 text-zinc-900 font-sans selection:bg-zinc-900 selection:text-white\">\n          {/* Navigation */}\n          <nav className={`fixed top-0 inset-x-0 z-50 transition-all duration-300 ${isScrolled ? \'bg-white/90 backdrop-blur-md border-b border-zinc-200 py-4\' : \'bg-transparent py-8\'}`}>\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center\">\n                  <span className={`font-bold text-xl tracking-tighter ${isScrolled ? \'text-zinc-900\' : \'text-white\'}`}>WUTTIPONG<span className=\"text-[#B28753]\">.</span></span>\n                  <div className=\"hidden md:flex gap-10 text-sm font-medium\">\n                      <a href=\"#about\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>About</a>\n                      <a href=\"#expertise\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Expertise</a>\n                      <a href=\"#experience\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Experience</a>\n                  </div>\n                  <a href=\"#contact\" className={`hidden md:inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-colors ${isScrolled ? \'bg-zinc-900 text-white hover:bg-zinc-800\' : \'bg-white text-zinc-900 hover:bg-zinc-100\'}`}>\n                      Get in touch\n                  </a>\n              </div>\n          </nav>\n\n          {/* Hero Section */}"
      replacement_content: "export default function App() {\n  const [isScrolled, setIsScrolled] = useState(false);\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n\n  useEffect(() => {\n      const handleScroll = () => {\n          setIsScrolled(window.scrollY > 50);\n      };\n      window.addEventListener(\'scroll\', handleScroll);\n      return () => window.removeEventListener(\'scroll\', handleScroll);\n  }, []);\n\n  // Prevent scrolling when mobile menu is open\n  useEffect(() => {\n      if (isMobileMenuOpen) {\n          document.body.style.overflow = \'hidden\';\n      } else {\n          document.body.style.overflow = \'unset\';\n      }\n  }, [isMobileMenuOpen]);\n\n  return (\n      <div className=\"min-h-screen bg-zinc-50 text-zinc-900 font-sans selection:bg-zinc-900 selection:text-white\">\n          {/* Navigation */}\n          <nav className={`fixed top-0 inset-x-0 z-50 transition-all duration-300 ${isScrolled ? \'bg-white/90 backdrop-blur-md border-b border-zinc-200 py-4\' : \'bg-transparent py-8\'}`}>\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center\">\n                  <span className={`font-bold text-xl tracking-tighter ${isScrolled ? \'text-zinc-900\' : \'text-white\'}`}>WUTTIPONG<span className=\"text-[#B28753]\">.</span></span>\n                  <div className=\"hidden md:flex gap-10 text-sm font-medium\">\n                      <a href=\"#about\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>About</a>\n                      <a href=\"#expertise\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Expertise</a>\n                      <a href=\"#experience\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Experience</a>\n                  </div>\n                  <a href=\"#contact\" className={`hidden md:inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-colors ${isScrolled ? \'bg-zinc-900 text-white hover:bg-zinc-800\' : \'bg-white text-zinc-900 hover:bg-zinc-100\'}`}>\n                      Get in touch\n                  </a>\n                  <button \n                      className={`md:hidden p-2 -mr-2 rounded-md ${isScrolled ? \'text-zinc-900\' : \'text-white\'}`}\n                      onClick={() => setIsMobileMenuOpen(true)}\n                  >\n                      <Menu className=\"w-6 h-6\" />\n                  </button>\n              </div>\n          </nav>\n\n          {/* Mobile Menu */}\n          {isMobileMenuOpen && (\n              <div className=\"fixed inset-0 z-[60] bg-zinc-950 text-white flex flex-col p-6 animate-in slide-in-from-top-4 duration-300\">\n                  <div className=\"flex justify-between items-center mt-2 mb-16\">\n                      <span className=\"font-bold text-xl tracking-tighter\">WUTTIPONG<span className=\"text-[#B28753]\">.</span></span>\n                      <button \n                          className=\"p-2 -mr-2 rounded-md text-zinc-400 hover:text-white\"\n                          onClick={() => setIsMobileMenuOpen(false)}\n                      >\n                          <X className=\"w-8 h-8\" />\n                      </button>\n                  </div>\n                  <div className=\"flex flex-col gap-10 text-3xl font-medium px-2\">\n                      <a href=\"#about\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">About</a>\n                      <a href=\"#expertise\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Expertise</a>\n                      <a href=\"#experience\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Experience</a>\n                      <a href=\"#contact\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors mt-8 pt-8 border-t border-zinc-800\">Get in touch</a>\n                  </div>\n              </div>\n          )}\n\n          {/* Hero Section */}"
    }
