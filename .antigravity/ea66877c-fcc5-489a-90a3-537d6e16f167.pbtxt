    instruction: "Wrap the mobile menu in AnimatePresence"
    replacement_infos {
      original_chunk {
        target_content: "          {/* Mobile Menu */}\n          {isMobileMenuOpen && (\n              <motion.div \n                  initial={{ opacity: 0, y: -20 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  exit={{ opacity: 0, y: -20 }}\n                  transition={{ duration: 0.3 }}\n                  className=\"fixed inset-0 z-[60] bg-zinc-950 text-white flex flex-col p-6\"\n              >\n                  <div className=\"flex justify-between items-center mt-2 mb-16\">\n                      <span className=\"font-bold text-xl tracking-tighter\">WUTTIPONG<span className=\"text-[#B28753]\">.</span></span>\n                      <button \n                          className=\"p-2 -mr-2 rounded-md text-zinc-400 hover:text-white\"\n                          onClick={() => setIsMobileMenuOpen(false)}\n                      >\n                          <X className=\"w-8 h-8\" />\n                      </button>\n                  </div>\n                  <div className=\"flex flex-col gap-10 text-3xl font-medium px-2\">\n                      <a href=\"#about\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">About</a>\n                      <a href=\"#expertise\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Expertise</a>\n                      <a href=\"#experience\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Experience</a>\n                      <a href=\"#contact\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors mt-8 pt-8 border-t border-zinc-800\">Get in touch</a>\n                  </div>\n              </motion.div>\n          )}"
        replacement_content: "          {/* Mobile Menu */}\n          <AnimatePresence>\n              {isMobileMenuOpen && (\n                  <motion.div \n                      key=\"mobile-menu\"\n                      initial={{ opacity: 0, y: -20 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      exit={{ opacity: 0, y: -20 }}\n                      transition={{ duration: 0.3 }}\n                      className=\"fixed inset-0 z-[60] bg-zinc-950 text-white flex flex-col p-6\"\n                  >\n                      <div className=\"flex justify-between items-center mt-2 mb-16\">\n                          <span className=\"font-bold text-xl tracking-tighter\">WUTTIPONG<span className=\"text-[#B28753]\">.</span></span>\n                          <button \n                              className=\"p-2 -mr-2 rounded-md text-zinc-400 hover:text-white\"\n                              onClick={() => setIsMobileMenuOpen(false)}\n                          >\n                              <X className=\"w-8 h-8\" />\n                          </button>\n                      </div>\n                      <div className=\"flex flex-col gap-10 text-3xl font-medium px-2\">\n                          <a href=\"#about\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">About</a>\n                          <a href=\"#expertise\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Expertise</a>\n                          <a href=\"#experience\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors\">Experience</a>\n                          <a href=\"#contact\" onClick={() => setIsMobileMenuOpen(false)} className=\"hover:text-[#B28753] transition-colors mt-8 pt-8 border-t border-zinc-800\">Get in touch</a>\n                      </div>\n                  </motion.div>\n              )}\n          </AnimatePresence>"
      }
      num_matches: 1
    }
  }
}
