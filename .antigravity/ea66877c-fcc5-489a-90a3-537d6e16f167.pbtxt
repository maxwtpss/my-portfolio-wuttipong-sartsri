    replacement_chunks {
      replacement_content: "import React, { useEffect, useState } from \'react\';\nimport { motion } from \'motion/react\';\nimport { \n  ArrowDownRight, Briefcase, GraduationCap, \n  Mail, Phone, Monitor, PenTool, Layout, BrainCircuit\n} from \'lucide-react\';\n\nconst SectionHeading = ({ title, subtitle }: { title: string, subtitle: React.ReactNode }) => (\n    <motion.div \n      initial={{ opacity: 0, y: 20 }}\n      whileInView={{ opacity: 1, y: 0 }}\n      viewport={{ once: true, margin: \"-100px\" }}\n      transition={{ duration: 0.6 }}\n      className=\"mb-16 md:mb-24\"\n    >\n        <h2 className=\"text-sm font-bold tracking-[0.2em] uppercase text-zinc-500 mb-6\">{title}</h2>\n        <div className=\"text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight text-zinc-900 leading-[1.1]\">\n            {subtitle}\n        </div>\n    </motion.div>\n);\n\nexport default function App() {\n  const [isScrolled, setIsScrolled] = useState(false);\n\n  useEffect(() => {\n      const handleScroll = () => {\n          setIsScrolled(window.scrollY > 50);\n      };\n      window.addEventListener(\'scroll\', handleScroll);\n      return () => window.removeEventListener(\'scroll\', handleScroll);\n  }, []);\n\n  return (\n      <div className=\"min-h-screen bg-zinc-50 text-zinc-900 font-sans selection:bg-zinc-900 selection:text-white\">\n          {/* Navigation */}\n          <nav className={`fixed top-0 inset-x-0 z-50 transition-all duration-300 ${isScrolled ? \'bg-white/90 backdrop-blur-md border-b border-zinc-200 py-4\' : \'bg-transparent py-8\'}`}>\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center\">\n                  <span className={`font-bold text-xl tracking-tighter ${isScrolled ? \'text-zinc-900\' : \'text-white\'}`}>WUTTIPONG.</span>\n                  <div className=\"hidden md:flex gap-10 text-sm font-medium\">\n                      <a href=\"#about\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>About</a>\n                      <a href=\"#expertise\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Expertise</a>\n                      <a href=\"#experience\" className={`${isScrolled ? \'text-zinc-600 hover:text-zinc-900\' : \'text-zinc-300 hover:text-white\'} transition-colors`}>Experience</a>\n                  </div>\n                  <a href=\"#contact\" className={`hidden md:inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-colors ${isScrolled ? \'bg-zinc-900 text-white hover:bg-zinc-800\' : \'bg-white text-zinc-900 hover:bg-zinc-100\'}`}>\n                      Get in touch\n                  </a>\n              </div>\n          </nav>\n\n          {/* Hero Section */}\n          <section className=\"relative min-h-screen flex items-center bg-zinc-950 text-white overflow-hidden pt-20\">\n              <div className=\"absolute inset-0 z-0\">\n                  <div className=\"absolute top-1/4 left-1/4 w-96 h-96 bg-zinc-800/50 blur-[128px] rounded-full mix-blend-screen\"></div>\n                  <div className=\"absolute bottom-1/4 right-1/8 w-96 h-96 bg-zinc-700/30 blur-[128px] rounded-full mix-blend-screen\"></div>\n              </div>\n              \n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 w-full relative z-10 pt-16\">\n                  <motion.div\n                      initial={{ opacity: 0, y: 30 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      transition={{ duration: 0.8, ease: \"easeOut\" }}\n                  >\n                      <h1 className=\"text-6xl sm:text-7xl md:text-[8rem] lg:text-[10rem] font-bold tracking-tighter leading-[0.9] mb-12\">\n                          Wuttipong <br className=\"hidden md:block\"/> Sartsri.\n                      </h1>\n                      <div className=\"grid md:grid-cols-12 gap-12 items-end\">\n                          <div className=\"md:col-span-8\">\n                             <p className=\"text-xl md:text-3xl text-zinc-400 font-light max-w-2xl leading-relaxed\">\n                                  Product Content Manager & UX/UI Specialist. <br className=\"hidden md:block\" />\n                                  Blending strategy, intuitive design, and AI.\n                              </p>\n                          </div>\n                          <div className=\"md:col-span-4 flex md:justify-end\">\n                              <a href=\"#about\" className=\"inline-flex items-center justify-center w-24 h-24 bg-white text-zinc-950 rounded-full hover:bg-zinc-200 hover:scale-105 transition-all\">\n                                  <ArrowDownRight className=\"w-8 h-8\" />\n                              </a>\n                          </div>\n                      </div>\n                  </motion.div>\n              </div>\n          </section>\n\n          {/* Profile Overview (About) */}\n          <section id=\"about\" className=\"py-24 md:py-32 bg-white\">\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 grid md:grid-cols-12 gap-12\">\n                   <div className=\"md:col-span-4\">\n                       <h2 className=\"text-sm font-bold tracking-[0.2em] uppercase text-zinc-500 mb-8\">Profile Info</h2>\n                       <ul className=\"space-y-6 text-zinc-600\">\n                           <li className=\"flex gap-4\"><span className=\"w-24 font-medium text-zinc-400 uppercase text-xs tracking-wider\">DOB</span> <span className=\"text-zinc-900\">January 4, 1998 (Age 28)</span></li>\n                           <li className=\"flex gap-4\"><span className=\"w-24 font-medium text-zinc-400 uppercase text-xs tracking-wider\">Phone</span> <span className=\"text-zinc-900\">094-8299360 <br/>063-8743559</span></li>\n                           <li className=\"flex gap-4\"><span className=\"w-24 font-medium text-zinc-400 uppercase text-xs tracking-wider\">Email</span> <span className=\"text-zinc-900\">wuttipong.sartsri@gmail.com</span></li>\n                           <li className=\"flex gap-4\"><span className=\"w-24 font-medium text-zinc-400 uppercase text-xs tracking-wider\">Location</span> <span className=\"text-zinc-900\">Bangmuang, Muang<br/>Samutprakan 10270</span></li>\n                       </ul>\n                   </div>\n                   <div className=\"md:col-span-8\">\n                       <h3 className=\"text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-zinc-900 leading-tight mb-12\">\n                           A dynamic professional bridging the gap between content strategy, user experience design, and AI-driven development. Highly flexible, ambitious, and passionate about continuous learning.\n                       </h3>\n                       <div className=\"flex flex-wrap gap-3\">\n                           {[\'Communication\', \'Teamwork\', \'Enthusiastic\', \'Highly Ambitious\', \'Honest & Reliable\', \'Sense of Responsibility\'].map((skill) => (\n                               <span key={skill} className=\"px-5 py-2.5 rounded-full border border-zinc-200 text-sm font-medium text-zinc-800\">\n                                   {skill}\n                               </span>\n                           ))}\n                       </div>\n                   </div>\n              </div>\n          </section>\n\n          {/* Expertise Section */}\n          <section id=\"expertise\" className=\"py-24 md:py-32 bg-zinc-50\">\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n                  <SectionHeading \n                      title=\"Area of Expertise\" \n                      subtitle={<>Delivering cross-disciplinary <br className=\"hidden md:block\"/> value in digital products.</>}\n                  />\n\n                  <div className=\"grid lg:grid-cols-3 gap-8\">\n                      <ExpertiseCard \n                          title=\"Content & Marketing\"\n                          icon={<PenTool className=\"w-6 h-6\" />}\n                          items={[\n                              \"Proficient in Product Content Writing.\",\n                              \"Write product descriptions and digital articles.\",\n                              \"SEO, Online Marketing or Online Advertising (Facebook Ads/Google Ads/ Social Media).\",\n                              \"Able to create infographics in many formats.\"\n                          ]}\n                      />\n                      <ExpertiseCard \n                          title=\"UX/UI & Layouts\"\n                          icon={<Layout className=\"w-6 h-6\" />}\n                          items={[\n                              \"UX/UI Design for intuitive systems and customer touchpoints.\",\n                              \"Designing data-rich analytics dashboards for actionable insights.\",\n                              \"Data Analysis: Analyzing performance metrics to refine strategies.\",\n                              \"Proficient in using computers, gadgets and electronic devices.\",\n                              \"Able to using MS (Word, PowerPoint, Excel) both Mac / PC Systems.\"\n                          ]}\n                      />\n                      <ExpertiseCard \n                          title=\"AI & Engineering\"\n                          icon={<BrainCircuit className=\"w-6 h-6\" />}\n                          items={[\n                              \"Prompt Engineering: Utilizing advanced AI prompting to streamline workflows.\",\n                              \"AI Web Apps: Developing simple, intelligent web applications using AI tools.\"\n                          ]}\n                      />\n                  </div>\n              </div>\n          </section>\n\n          {/* Experience Section */}\n          <section id=\"experience\" className=\"py-24 md:py-32 bg-white\">\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n                  <SectionHeading \n                      title=\"Professional Experience\" \n                      subtitle={<>A track record of growth <br className=\"hidden md:block\"/> and leadership.</>}\n                  />\n\n                  <div className=\"space-y-16\">\n                      <ExperienceRow \n                          role=\"Product Content, Department Manager\"\n                          company=\"B2S (Central Retail) - Central Group\"\n                          period=\"Apr 2022 \342\200\223 Present\"\n                          description=\"Spearheading the evolution of product content through modern design and AI-driven workflows. Promoted to manage the department, expanding responsibilities into digital product design and analytics.\"\n                          achievements={[\n                              \"UX/UI Design: Creating intuitive interfaces for internal systems and customer touchpoints.\",\n                              \"Dashboard Layouts: Designing data-rich analytics dashboards for actionable insights.\",\n                              \"Prompt Engineering: Utilizing advanced AI prompting to streamline content creation.\",\n                              \"AI Web Apps: Developing simple, intelligent web applications using AI tools.\",\n                              \"Data Analysis: Analyzing performance metrics to refine content strategies.\"\n                          ]}\n                      />\n\n                      <div className=\"h-px bg-zinc-200 w-full\" />\n\n                      <ExperienceRow \n                          role=\"Digital Content Writer\"\n                          company=\"Home Product Center Pub Co., Ltd.\"\n                          period=\"2021 \342\200\223 Mar 2022\"\n                          description=\"Authored compelling product descriptions and digital articles to drive engagement while overseeing online marketing campaigns.\"\n                          achievements={[\n                              \"Authored product descriptions and digital articles.\",\n                              \"Executed SEO strategies and managed Facebook/Google Ads.\",\n                              \"Created multi-format infographics and visual content.\"\n                          ]}\n                      />\n                  </div>\n              </div>\n          </section>\n\n          {/* Education & Certs */}\n          <section className=\"py-24 md:py-32 bg-zinc-950 text-white\">\n              <div className=\"max-w-7xl mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 lg:gap-24\">\n                  \n                  <div>\n                      <h2 className=\"text-3xl lg:text-4xl font-medium tracking-tight mb-16 flex items-center gap-4\">\n                          <GraduationCap className=\"w-8 h-8 text-zinc-500\" /> Education\n                      </h2>\n                      <div className=\"space-y-12\">\n                          <div className=\"relative pl-6 border-l border-zinc-800\">\n                              <div className=\"absolute top-0 -left-[5px] w-2 h-2 rounded-full bg-zinc-500\"></div>\n                              <p className=\"text-zinc-500 font-mono text-sm mb-3\">2016 \342\200\223 2019</p>\n                              <h3 className=\"text-2xl lg:text-3xl font-medium mb-2\">Ramkhamhaeng University</h3>\n                              <p className=\"text-xl text-zinc-400 mb-6\">B.A. in Mass Communication</p>\n                              <ul className=\"text-zinc-500 space-y-2\">\n                                  <li>\342\200\242 Major in Mass Communication</li>\n                                  <li>\342\200\242 Minor in Advertising</li>\n                              </ul>\n                          </div>\n                      </div>\n                  </div>\n\n                  <div>\n                      <h2 className=\"text-3xl lg:text-4xl font-medium tracking-tight mb-16 flex items-center gap-4\">\n                          <Briefcase className=\"w-8 h-8 text-zinc-500\" /> Certifications\n                      </h2>\n                      <div className=\"space-y-12\">\n                          <div className=\"group border-b border-zinc-800 pb-10\">\n                              <p className=\"text-zinc-500 font-mono text-sm mb-3\">February 2020</p>\n                              <h3 className=\"text-2xl lg:text-3xl font-medium mb-3 transition-colors\">Infographic Design</h3>\n                              <p className=\"text-zinc-400 text-lg\">Srinakharinwirot University (Thai-MOOC)</p>\n                          </div>\n                          <div className=\"group border-b border-zinc-800 pb-10\">\n                              <p className=\"text-zinc-500 font-mono text-sm mb-3\">June 2020</p>\n                              <h3 className=\"text-2xl lg:text-3xl font-medium mb-3 transition-colors\">Creative Marketing</h3>\n                              <p className=\"text-zinc-400 text-lg\">Ming Chuan Univ. & National Open Univ.</p>\n                          </div>\n                      </div>\n                  </div>\n\n              </div>\n          </section>\n\n          {/* Footer Contact */}\n          <footer id=\"contact\" className=\"py-24 md:py-32 bg-zinc-50 text-center\">\n              <div className=\"max-w-4xl mx-auto px-6\">\n                  <h2 className=\"text-5xl md:text-7xl font-medium tracking-tight text-zinc-900 mb-8\">\n                      Let\'s work together.\n                  </h2>\n                  <p className=\"text-xl md:text-2xl text-zinc-500 mb-16 max-w-2xl mx-auto\">\n                      Always open to discussing product content, UX/UI design, or AI engineering opportunities.\n                  </p>\n                  \n                  <div className=\"flex flex-col md:flex-row items-center justify-center gap-6 mb-24\">\n                      <a href=\"mailto:wuttipong.sartsri@gmail.com\" className=\"inline-flex items-center gap-3 px-8 py-5 bg-zinc-900 text-white rounded-full text-lg font-medium hover:bg-zinc-800 transition-colors w-full md:w-auto justify-center\">\n                          <Mail className=\"w-5 h-5\" /> wuttipong.sartsri@gmail.com\n                      </a>\n                      <a href=\"tel:0948299360\" className=\"inline-flex items-center gap-3 px-8 py-5 border border-zinc-300 text-zinc-900 rounded-full text-lg font-medium hover:bg-zinc-100 transition-colors w-full md:w-auto justify-center\">\n                          <Phone className=\"w-5 h-5\" /> 094-8299360\n                      </a>\n                  </div>\n\n                  <div className=\"border-t border-zinc-200 pt-8 flex flex-col md:flex-row items-center justify-between text-sm text-zinc-500\">\n                      <p>\302\251 {new Date().getFullYear()} Wuttipong Sartsri. All rights reserved.</p>\n                      <p className=\"mt-2 md:mt-0 font-medium\">Designed & Built with modern web technologies.</p>\n                  </div>\n              </div>\n          </footer>\n      </div>\n  );\n}\n\nfunction ExpertiseCard({ title, icon, items }: { title: string, icon: React.ReactNode, items: string[] }) {\n    return (\n        <motion.div \n            initial={{ opacity: 0, y: 20 }}\n            whileInView={{ opacity: 1, y: 0 }}\n            viewport={{ once: true, margin: \"-50px\" }}\n            transition={{ duration: 0.5 }}\n            className=\"p-8 md:p-10 bg-white rounded-3xl shadow-sm border border-zinc-100 flex flex-col h-full\"\n        >\n            <div className=\"w-16 h-16 bg-zinc-50 text-zinc-900 rounded-2xl flex items-center justify-center mb-8 border border-zinc-200\">\n                {icon}\n            </div>\n            <h3 className=\"text-2xl md:text-3xl font-medium mb-8 text-zinc-900\">{title}</h3>\n            <ul className=\"space-y-5 mt-auto\">\n                {items.map((item, idx) => (\n                    <li key={idx} className=\"flex items-start gap-4 text-zinc-600\">\n                        <div className=\"w-1.5 h-1.5 rounded-full bg-zinc-400 mt-2.5 shrink-0\" />\n                        <span className=\"leading-relaxed text-lg\">{item}</span>\n                    </li>\n                ))}\n            </ul>\n        </motion.div>\n    );\n}\n\nfunction ExperienceRow({ role, company, period, description, achievements }: { role: string, company: string, period: string, description: string, achievements: string[] }) {\n    return (\n        <motion.div \n            initial={{ opacity: 0, y: 20 }}\n            whileInView={{ opacity: 1, y: 0 }}\n            viewport={{ once: true, margin: \"-50px\" }}\n            transition={{ duration: 0.5 }}\n            className=\"grid lg:grid-cols-12 gap-8 lg:gap-16\"\n        >\n            <div className=\"lg:col-span-4\">\n                <p className=\"text-sm font-bold tracking-widest uppercase text-zinc-400 mb-3\">{period}</p>\n                <h3 className=\"text-3xl font-medium text-zinc-900 mb-3 leading-tight\">{role}</h3>\n                <p className=\"text-xl text-zinc-500\">{company}</p>\n            </div>\n            <div className=\"lg:col-span-8\">\n                <p className=\"text-xl md:text-2xl text-zinc-600 leading-relaxed mb-10 font-light\">\n                    {description}\n                </p>\n                <div className=\"space-y-4\">\n                    {achievements.map((item, idx) => {\n                        const parts = item.split(\': \');\n                        return (\n                            <div key={idx} className=\"flex items-start gap-4 text-zinc-600 border-l border-zinc-300 pl-6 py-1\">\n                                {parts.length > 1 ? (\n                                    <span className=\"text-lg\"><strong className=\"text-zinc-900 font-medium\">{parts[0]}:</strong> {parts[1]}</span>\n                                ) : (\n                                    <span className=\"text-lg\">{item}</span>\n                                )}\n                            </div>\n                        );\n                    })}\n                </div>\n            </div>\n        </motion.div>\n    );\n}\n"
    }
