  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nexport default function App() {\n  return <div></div>;\n}"
      replacement_content: "import React, { useState } from \'react\';\nimport { \n  Mail, Phone, MapPin, Calendar, Briefcase, GraduationCap, \n  Award, Monitor, Code, Layout, Layers, User, ChevronRight, \n  Database, Sparkles, PenTool, BarChart3, LineChart\n} from \'lucide-react\';\n\nexport default function App() {\n  const [activeMenu, setActiveMenu] = useState(\'about\');\n\n  return (\n    <div className=\"min-h-screen bg-slate-50 text-slate-800 font-sans selection:bg-indigo-100 selection:text-indigo-900\">\n      \n      {/* Header / Hero Section */}\n      <header className=\"bg-white border-b border-slate-200\">\n        <div className=\"max-w-6xl mx-auto px-6 py-16 sm:py-24 grid md:grid-cols-3 gap-10 items-center\">\n          <div className=\"md:col-span-2 space-y-6\">\n            <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-sm font-medium\">\n              <Sparkles className=\"w-4 h-4\" />\n              <span>Available for new opportunities</span>\n            </div>\n            <h1 className=\"text-4xl sm:text-5xl font-bold tracking-tight text-slate-900\">\n              Wuttipong Sartsri\n            </h1>\n            <h2 className=\"text-xl sm:text-2xl text-slate-600 font-medium\">\n              Product Content Department Manager <br className=\"hidden sm:block\"/>& UX/UI Developer\n            </h2>\n            <p className=\"text-slate-600 leading-relaxed max-w-2xl text-lg\">\n              A dynamic professional bridging the gap between content strategy, user experience design, and AI-driven development. Highly flexible, ambitious, and passionate about continuous learning.\n            </p>\n            <div className=\"flex flex-wrap gap-4 pt-4\">\n              <a href=\"#contact\" className=\"inline-flex items-center justify-center gap-2 px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium\">\n                <Mail className=\"w-4 h-4\" />\n                Contact Me\n              </a>\n              <a href=\"#portfolio\" className=\"inline-flex items-center justify-center gap-2 px-6 py-3 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-colors font-medium\">\n                <Layout className=\"w-4 h-4\" />\n                View Portfolio\n              </a>\n            </div>\n          </div>\n          \n          <div className=\"hidden md:flex justify-center\">\n            {/* Abstract Profile Placeholder */}\n            <div className=\"relative w-64 h-64 rounded-full bg-gradient-to-tr from-indigo-100 to-slate-100 border-4 border-white shadow-xl flex items-center justify-center overflow-hidden\">\n              <User className=\"w-24 h-24 text-indigo-300\" />\n              <div className=\"absolute inset-0 bg-gradient-to-tr from-transparent via-transparent to-white/30 mix-blend-overlay\"></div>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Content Area */}\n      <main className=\"max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-12 gap-12\">\n        \n        {/* Sidebar */}\n        <div className=\"md:col-span-4 space-y-8\">\n          \n          {/* Contact Details */}\n          <section className=\"bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-6\">\n            <h3 className=\"text-sm font-bold tracking-widest text-slate-400 uppercase\">Personal Info</h3>\n            <div className=\"space-y-4\">\n              <div className=\"flex items-start gap-4\">\n                <div className=\"p-2 bg-slate-50 rounded-lg text-slate-500 shrink-0\">\n                  <Calendar className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"font-medium text-slate-900\">Date of Birth</p>\n                  <p className=\"text-slate-600 text-sm\">January 4, 1998 (Age 28)</p>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-4\">\n                <div className=\"p-2 bg-slate-50 rounded-lg text-slate-500 shrink-0\">\n                  <Phone className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"font-medium text-slate-900\">Phone</p>\n                  <p className=\"text-slate-600 text-sm\">094-8299360, 063-8743559</p>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-4\">\n                <div className=\"p-2 bg-slate-50 rounded-lg text-slate-500 shrink-0\">\n                  <Mail className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"font-medium text-slate-900\">Email</p>\n                  <p className=\"text-slate-600 text-sm break-all\">wuttipong.sartsri@gmail.com</p>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-4\">\n                <div className=\"p-2 bg-slate-50 rounded-lg text-slate-500 shrink-0\">\n                  <MapPin className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"font-medium text-slate-900\">Location</p>\n                  <p className=\"text-slate-600 text-sm\">106/10 M.3 Bangmuang, Muang<br/>Samutprakan 10270</p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          {/* Soft Skills */}\n          <section className=\"bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-6\">\n            <h3 className=\"text-sm font-bold tracking-widest text-slate-400 uppercase\">Interpersonal Skills</h3>\n            <div className=\"flex flex-wrap gap-2\">\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Communication</span>\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Teamwork</span>\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Enthusiastic</span>\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Highly Ambitious</span>\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Honest & Reliable</span>\n              <span className=\"px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-md\">Sense of Responsibility</span>\n            </div>\n          </section>\n\n          {/* Education */}\n          <section className=\"bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-6\">\n            <h3 className=\"text-sm font-bold tracking-widest text-slate-400 uppercase\">Education</h3>\n            <div className=\"relative pl-6 border-l-2 border-slate-100 space-y-8\">\n              <div className=\"relative\">\n                <div className=\"absolute w-3 h-3 bg-white border-2 border-indigo-400 rounded-full -left-[31px] top-1.5\"></div>\n                <h4 className=\"font-semibold text-slate-900\">Ramkhamhaeng University</h4>\n                <p className=\"text-slate-600 text-sm mt-1\">B.A. in Mass Communication</p>\n                <ul className=\"text-slate-500 text-sm mt-2 space-y-1 list-disc list-inside\">\n                  <li>Major in Mass Communication</li>\n                  <li>Minor in Advertising</li>\n                </ul>\n                <p className=\"text-slate-400 text-xs font-medium mt-2\">2016 \342\200\223 2019</p>\n              </div>\n            </div>\n          </section>\n\n        </div>\n\n        {/* Main Column */}\n        <div className=\"md:col-span-8 space-y-12\">\n          \n          {/* Experience */}\n          <section id=\"experience\" className=\"scroll-mt-24 space-y-6\">\n            <div className=\"flex items-center gap-3 border-b border-slate-200 pb-4\">\n              <Briefcase className=\"w-6 h-6 text-indigo-600\" />\n              <h2 className=\"text-2xl font-bold text-slate-900\">Work Experience</h2>\n            </div>\n            \n            <div className=\"space-y-8\">\n              {/* Current Job */}\n              <div className=\"bg-white rounded-2xl p-6 border border-slate-200 shadow-sm transition-shadow hover:shadow-md block relative overflow-hidden\">\n                <div className=\"absolute top-0 left-0 w-1 h-full bg-indigo-500\"></div>\n                <div className=\"flex flex-col sm:flex-row sm:items-start justify-between mb-4 gap-2\">\n                  <div>\n                    <h3 className=\"text-xl font-bold text-slate-900 text-balance\">Product Content, Department Manager</h3>\n                    <p className=\"text-indigo-600 font-medium mt-1\">Home Product Center Pub Co., Ltd.</p>\n                  </div>\n                  <span className=\"inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-sm font-semibold shrink-0\">\n                    Apr 2022 \342\200\223 Present\n                  </span>\n                </div>\n                <p className=\"text-slate-600 leading-relaxed mb-6\">\n                  Spearheading the evolution of product content through modern design and AI-driven workflows. Promoted to manage the department, expanding responsibilities into digital product design and analytics.\n                </p>\n                \n                <h4 className=\"text-sm font-bold text-slate-900 uppercase tracking-wider mb-3\">Key Responsibilities & Achievements:</h4>\n                <ul className=\"grid sm:grid-cols-2 gap-3 text-slate-600\">\n                  <li className=\"flex items-start gap-2\">\n                    <ChevronRight className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n                    <span><strong className=\"text-slate-800\">UX/UI Design:</strong> Creating intuitive user interfaces for internal systems and customer touchpoints.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <ChevronRight className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n                    <span><strong className=\"text-slate-800\">Dashboard Layouts:</strong> Designing data-rich analytics dashboards for actionable insights.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <ChevronRight className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n                    <span><strong className=\"text-slate-800\">Prompt Engineering:</strong> Utilizing advanced AI prompting to streamline content creation workflows.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <ChevronRight className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n                    <span><strong className=\"text-slate-800\">AI Web Apps:</strong> Developing simple, intelligent web applications using AI generation tools.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <ChevronRight className=\"w-5 h-5 text-indigo-400 shrink-0\" />\n                    <span><strong className=\"text-slate-800\">Data Analysis:</strong> Analyzing performance metrics to refine content and layout strategies.</span>\n                  </li>\n                </ul>\n              </div>\n\n              {/* Previous Job */}\n              <div className=\"bg-white rounded-2xl p-6 border border-slate-200 shadow-sm relative\">\n                <div className=\"absolute top-0 left-0 w-1 h-full bg-slate-300 rounded-l-2xl\"></div>\n                <div className=\"flex flex-col sm:flex-row sm:items-start justify-between mb-4 gap-2\">\n                  <div>\n                    <h3 className=\"text-lg font-bold text-slate-900\">Digital Content Writer</h3>\n                    <p className=\"text-slate-500 font-medium mt-1\">Home Product Center Pub Co., Ltd.</p>\n                  </div>\n                  <span className=\"inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-sm font-medium shrink-0\">\n                    2021 \342\200\223 Mar 2022\n                  </span>\n                </div>\n                <ul className=\"space-y-2 text-slate-600\">\n                  <li className=\"flex items-start gap-2\">\n                    <span className=\"mt-2 w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0\"></span>\n                    <span>Authored compelling product descriptions and digital articles to drive engagement.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <span className=\"mt-2 w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0\"></span>\n                    <span>Executed SEO strategies and managed online advertising campaigns across Facebook Ads and Google Ads.</span>\n                  </li>\n                  <li className=\"flex items-start gap-2\">\n                    <span className=\"mt-2 w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0\"></span>\n                    <span>Created multi-format infographics and visual content for marketing collateral.</span>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </section>\n\n          {/* Hard Skills & Tools */}\n          <section className=\"space-y-6\">\n            <div className=\"flex items-center gap-3 border-b border-slate-200 pb-4\">\n              <Layers className=\"w-6 h-6 text-indigo-600\" />\n              <h2 className=\"text-2xl font-bold text-slate-900\">Professional Skills</h2>\n            </div>\n            \n            <div className=\"grid sm:grid-cols-2 gap-6\">\n              \n              <div className=\"bg-slate-900 text-slate-100 rounded-2xl p-6 shadow-md\">\n                <div className=\"flex items-center gap-3 mb-6\">\n                  <Monitor className=\"w-5 h-5 text-indigo-400\" />\n                  <h3 className=\"font-semibold text-lg text-white\">Design & Technology</h3>\n                </div>\n                <ul className=\"space-y-4\">\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium\"><span>UX/UI Design</span></div>\n                    <div className=\"w-full bg-slate-800 rounded-full h-2\">\n                      <div className=\"bg-indigo-400 h-2 rounded-full\" style={{ width: \'90%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium\"><span>Dashboard & Data Layouts</span></div>\n                    <div className=\"w-full bg-slate-800 rounded-full h-2\">\n                      <div className=\"bg-indigo-400 h-2 rounded-full\" style={{ width: \'85%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium\"><span>Prompt Engineering & AI Tools</span></div>\n                    <div className=\"w-full bg-slate-800 rounded-full h-2\">\n                      <div className=\"bg-indigo-400 h-2 rounded-full\" style={{ width: \'85%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium\"><span>Data Analysis</span></div>\n                    <div className=\"w-full bg-slate-800 rounded-full h-2\">\n                      <div className=\"bg-indigo-400 h-2 rounded-full\" style={{ width: \'75%\' }}></div>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n\n              <div className=\"bg-white border border-slate-200 rounded-2xl p-6 shadow-sm\">\n                <div className=\"flex items-center gap-3 mb-6\">\n                  <PenTool className=\"w-5 h-5 text-indigo-600\" />\n                  <h3 className=\"font-semibold text-lg text-slate-900\">Content & Marketing</h3>\n                </div>\n                <ul className=\"space-y-4\">\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium text-slate-700\"><span>Product Content Writing</span></div>\n                    <div className=\"w-full bg-slate-100 rounded-full h-2\">\n                      <div className=\"bg-slate-400 h-2 rounded-full\" style={{ width: \'95%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium text-slate-700\"><span>SEO & Digital Articles</span></div>\n                    <div className=\"w-full bg-slate-100 rounded-full h-2\">\n                      <div className=\"bg-slate-400 h-2 rounded-full\" style={{ width: \'90%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium text-slate-700\"><span>Facebook / Google Ads</span></div>\n                    <div className=\"w-full bg-slate-100 rounded-full h-2\">\n                      <div className=\"bg-slate-400 h-2 rounded-full\" style={{ width: \'80%\' }}></div>\n                    </div>\n                  </li>\n                  <li>\n                    <div className=\"flex justify-between mb-1 text-sm font-medium text-slate-700\"><span>Infographic Design</span></div>\n                    <div className=\"w-full bg-slate-100 rounded-full h-2\">\n                      <div className=\"bg-slate-400 h-2 rounded-full\" style={{ width: \'85%\' }}></div>\n                    </div>\n                  </li>\n                </ul>\n              </div>\n\n            </div>\n          </section>\n\n          {/* Portfolio Highlights */}\n          <section id=\"portfolio\" className=\"scroll-mt-24 space-y-6\">\n            <div className=\"flex items-center gap-3 border-b border-slate-200 pb-4\">\n              <Code className=\"w-6 h-6 text-indigo-600\" />\n              <h2 className=\"text-2xl font-bold text-slate-900\">Portfolio Highlights</h2>\n            </div>\n            \n            <div className=\"grid sm:grid-cols-2 gap-6\">\n              \n              {/* Portfolio Item 1 */}\n              <div className=\"group bg-white border border-slate-200 rounded-2xl overflow-hidden hover:shadow-lg transition-all duration-300 cursor-pointer\">\n                <div className=\"h-40 bg-slate-100 border-b border-slate-200 flex items-center justify-center group-hover:bg-indigo-50 transition-colors p-6\">\n                   <div className=\"w-full h-full bg-white rounded shadow-sm border border-slate-200 p-2 flex flex-col gap-2 relative overflow-hidden\">\n                     <div className=\"flex gap-2 border-b border-slate-100 pb-2\">\n                       <div className=\"w-1/4 h-2 bg-indigo-100 rounded\"></div>\n                       <div className=\"w-1/4 h-2 bg-indigo-100 rounded\"></div>\n                     </div>\n                     <div className=\"flex-1 flex gap-2\">\n                       <div className=\"w-1/3 h-full bg-slate-50 rounded hidden sm:block\"></div>\n                       <div className=\"flex-1 bg-gradient-to-br from-indigo-50 to-slate-50 rounded\"></div>\n                     </div>\n                   </div>\n                </div>\n                <div className=\"p-6\">\n                  <div className=\"flex items-center gap-2 mb-2\">\n                    <BarChart3 className=\"w-4 h-4 text-indigo-600\" />\n                    <span className=\"text-xs font-bold uppercase tracking-wider text-indigo-600\">UX/UI & Analytics</span>\n                  </div>\n                  <h3 className=\"font-bold text-lg text-slate-900 mb-2\">Data Analytics Dashboard</h3>\n                  <p className=\"text-slate-600 text-sm\">\n                    A comprehensive dashboard layout designing to visualize complex performance metrics, allowing teams to analyze data intuitively and make informed decisions.\n                  </p>\n                </div>\n              </div>\n\n              {/* Portfolio Item 2 */}\n              <div className=\"group bg-white border border-slate-200 rounded-2xl overflow-hidden hover:shadow-lg transition-all duration-300 cursor-pointer\">\n                <div className=\"h-40 bg-slate-100 border-b border-slate-200 flex items-center justify-center group-hover:bg-indigo-50 transition-colors p-6\">\n                  <div className=\"w-full h-full bg-slate-900 rounded shadow-sm p-4 relative overflow-hidden flex flex-col items-center justify-center text-center\">\n                    <Sparkles className=\"w-8 h-8 text-indigo-400 mb-2\" />\n                    <div className=\"w-3/4 h-1.5 bg-slate-700 rounded-full mb-1\"></div>\n                    <div className=\"w-1/2 h-1.5 bg-slate-700 rounded-full\"></div>\n                  </div>\n                </div>\n                <div className=\"p-6\">\n                  <div className=\"flex items-center gap-2 mb-2\">\n                    <Monitor className=\"w-4 h-4 text-indigo-600\" />\n                    <span className=\"text-xs font-bold uppercase tracking-wider text-indigo-600\">AI Prompt Engineering</span>\n                  </div>\n                  <h3 className=\"font-bold text-lg text-slate-900 mb-2\">AI-Generated Web Application</h3>\n                  <p className=\"text-slate-600 text-sm\">\n                    Developed functional web app interfaces leveraging prompt engineering and AI tools, significantly accelerating the rapid prototyping process for new features.\n                  </p>\n                </div>\n              </div>\n\n            </div>\n          </section>\n\n          {/* Certificates */}\n          <section className=\"space-y-6\">\n            <div className=\"flex items-center gap-3 border-b border-slate-200 pb-4\">\n              <Award className=\"w-6 h-6 text-indigo-600\" />\n              <h2 className=\"text-2xl font-bold text-slate-900\">Certifications</h2>\n            </div>\n            \n            <div className=\"grid sm:grid-cols-2 gap-4\">\n              <div className=\"bg-white border border-slate-200 rounded-xl p-5 flex items-start gap-4\">\n                <div className=\"p-3 bg-indigo-50 text-indigo-600 rounded-lg shrink-0\">\n                  <FileText className=\"w-6 h-6\" />\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-slate-900 leading-tight\">Infographic Design</h4>\n                  <p className=\"text-slate-600 text-sm mt-1\">Srinakharinwirot University (Thai-MOOC)</p>\n                  <p className=\"text-slate-400 text-xs font-medium mt-2\">February 2020</p>\n                </div>\n              </div>\n              \n              <div className=\"bg-white border border-slate-200 rounded-xl p-5 flex items-start gap-4\">\n                <div className=\"p-3 bg-indigo-50 text-indigo-600 rounded-lg shrink-0\">\n                  <LineChart className=\"w-6 h-6\" />\n                </div>\n                <div>\n                  <h4 className=\"font-bold text-slate-900 leading-tight\">Creative Marketing</h4>\n                  <p className=\"text-slate-600 text-sm mt-1\">Ming Chuan Univ. & National Open Univ.</p>\n                  <p className=\"text-slate-400 text-xs font-medium mt-2\">June 2020</p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n        </div>\n      </main>\n\n      {/* Footer */}\n      <footer id=\"contact\" className=\"bg-slate-900 text-slate-400 py-12 text-center\">\n        <div className=\"max-w-6xl mx-auto px-6\">\n          <p className=\"mb-4\">Designed and built with modern web technologies.</p>\n          <div className=\"flex justify-center gap-6\">\n            <a href=\"mailto:wuttipong.sartsri@gmail.com\" className=\"hover:text-white transition-colors flex items-center gap-2\">\n              <Mail className=\"w-4 h-4\" /> Email\n            </a>\n            <span className=\"hover:text-white transition-colors flex items-center gap-2\">\n              <Phone className=\"w-4 h-4\" /> 094-8299360\n            </span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
